<style>
  main {
    overflow-x: hidden;
    min-height: calc(100vh - var(--header-height));
    display: flex;
  }

  #section-container {
    border-inline: 1px solid
      color-mix(in oklch, var(--color-neutral-950) 10%, transparent);
    margin-inline: var(--space-6);
  }
  .non-hero-section {
    padding-inline: var(--space-1);
  }

  .heading-container {
    height: clamp(200px, 28vw, 400px);
    position: relative;
  }
  .heading-container::before {
    content: "";
    z-index: 1;
    width: 200vw;
    height: 1px;
    position: absolute;
    background-color: color-mix(
      in oklab,
      var(--color-neutral-950) 10%,
      transparent
    );
    left: -100vw;
    top: 0;
  }
  .heading-container::after {
    content: "";
    z-index: 1;
    width: 200vw;
    height: 1px;
    position: absolute;
    background-color: color-mix(
      in oklab,
      var(--color-neutral-950) 10%,
      transparent
    );
    left: -100vw;
    bottom: 0;
  }

  .title {
    z-index: 1;
