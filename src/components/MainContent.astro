    max-width: none;
    pointer-events: none;
  }

  .heading-underline {
    position: relative;
  }
  .heading-underline::after {
    content: "";
    width: 200vw;
    height: 1px;
    position: absolute;
    background-color: color-mix(
      in oklab,
      var(--color-neutral-950) 10%,
      transparent
    );
    left: -100vw;
    bottom: 0;
  }

  h2.heading-underline::after {
    bottom: 20px;
  }

  .element-with-cross {
    position: relative;
    border: 1px solid var(--color-border);
  }

  .element-with-cross::before,
  .element-with-cross::after {
    content: "";
    position: absolute;
    width: 1rem;
    height: 1rem;
    pointer-events: none;
    color: color-mix(in oklch, var(--color-border) 70%, var(--color-text));
    background:
      linear-gradient(currentColor, currentColor) center / 100% 2px no-repeat,
